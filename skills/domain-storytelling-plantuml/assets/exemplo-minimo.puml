@startuml
!include https://raw.githubusercontent.com/johthor/DomainStory-PlantUML/main/domainStory.puml

Boundary(ExemploReserva) {
    Person(Cliente)
    Document(Reserva)
    Person(Atendente)
}

activity(_, Cliente, solicita, Reserva, para, Atendente)
activity(_, Atendente, confirma, Reserva, para, Cliente)
@enduml
